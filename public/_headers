# Service Worker - 절대 캐시하지 않음
/static/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

# App JS/CSS - 항상 최신 버전 로드
/static/app.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/static/app.css
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

# Archive Module - 항상 최신 버전 로드
/modules/records/*
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
